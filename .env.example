# Runtime Identity (isolated from telegram production)
TELEGRAM_BOT_TOKEN=your_separate_token_for_bale_project
TELEGRAM_BOT_USERNAME=Night77_tube_bot
ALLOWED_USER_IDS=971043547
ALLOWED_CHAT_IDS=

# Bale primary settings
BALE_FORWARD_ENABLED=true
BALE_BOT_TOKEN=your_bale_bot_token_here
BALE_CHAT_ID=your_bale_chat_id

# Download Configuration
DOWNLOADS_DIR=./downloads

# AI Summary Configuration
YTSUMMARIZE_CLI=/usr/local/bin/ytsummarize

# Rate Limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=10

# Bale Bridge (optional)
BALE_FORWARD_ENABLED=false
BALE_BOT_TOKEN=your_bale_bot_token_here
BALE_CHAT_ID=your_bale_chat_id

# Short-lived file cache (reuse recent outputs)
FILE_CACHE_ENABLED=true
FILE_CACHE_TTL_SECONDS=3600
BALE_SAFE_MAX_MB=20
DIRECT_MAX_MB=500

# Optional comma-separated mirrors (prefixes) for GitHub asset downloads
# Example: https://ghproxy.com/,https://mirror.ghproxy.com/
GITHUB_DOWNLOAD_MIRRORS=
